# This is a placeholder .env file
# Copy this to .env and update with your actual values

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/edufinance?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="development-secret-key-change-in-production"
JWT_REFRESH_SECRET="development-refresh-secret-key"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# App
PORT=4000
NODE_ENV=development
API_VERSION=v1
API_URL="http://localhost:4000"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="text"

# ZATCA (Fatoora) - Register at https://fatoora.zatca.gov.sa
ZATCA_API_URL="https://gw.fatoora.zatca.com"
ZATCA_CLIENT_ID="your-client-id"
ZATCA_CLIENT_SECRET="your-client-secret"
ZATCA_VAT_NUMBER="300000000000003"

# AWS S3
S3_BUCKET="edufinance-documents"
S3_REGION="me-south-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"

# Payment Gateways
SADAD_URL="https://uat.sadad.com"
SADAD_MERCHANT_ID="your-merchant-id"
SADAD_API_KEY="your-api-key"

MADA_URL="https://uat.mada.com.sa"
MADA_TERMINAL_ID="your-terminal-id"
MADA_PASSWORD="your-password"

# SMS
SMS_GATEWAY_URL="https://api.smsgateway.com"
SMS_API_KEY="your-sms-api-key"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@edufinance.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="EduFinance <noreply@edufinance.com>"