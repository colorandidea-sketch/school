# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/edufinance?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Application
PORT=4000
NODE_ENV=development
API_VERSION=v1

# ZATCA Configuration
ZATCA_API_URL="https://gw.fatoora.zatca.com"
ZATCA_CLIENT_ID="your-client-id"
ZATCA_CLIENT_SECRET="your-client-secret"
ZATCA_VAT_NUMBER="300000000000003"

# File Storage (S3)
S3_BUCKET="edufinance-documents"
S3_REGION="me-south-1"
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"

# Payment Gateways
SADAD_URL="https://uat.sadad.com"
SADAD_MERCHANT_ID="your-sadad-merchant-id"
SADAD_API_KEY="your-sadad-api-key"

MADA_URL="https://uat.mada.com.sa"
MADA_TERMINAL_ID="your-mada-terminal-id"
MADA_PASSWORD="your-mada-password"

# SMS/Notification
SMS_GATEWAY_URL="https://api.smsgateway.com"
SMS_API_KEY="your-sms-api-key"
WHATSAPP_BUSINESS_TOKEN="your-whatsapp-token"

# Email
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="noreply@edufinance.com"
SMTP_PASSWORD="your-smtp-password"
SMTP_FROM="EduFinance <noreply@edufinance.com>"

# Logging
LOG_LEVEL="info"
LOG_FORMAT="json"